# ── Core ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
FIREBASE_PROJECT_ID=your_firebase_project_id
PORT=3000
NODE_ENV=development
HASH_SALT=change_this_to_a_random_string_in_production

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/selidiki

# ── Feature Flags (Sprint 2A) ──────────────────────────────
# Kill Switch — set to false to force Firestore-only (emergency brake)
ENABLE_DATABASE_SWITCHING=false

# Legacy provider selector (backward compatible)
DATABASE_PROVIDER=FIRESTORE

# Provider flags
ENABLE_FIRESTORE=true
ENABLE_POSTGRES=false

# Mode flags (require ENABLE_POSTGRES=true)
ENABLE_DUAL_WRITE=false
ENABLE_DUAL_READ=false
ENABLE_SHADOW_MODE=false

# Observability flags
ENABLE_PARITY_LOGGING=false
ENABLE_WRITE_VERIFY=false
ENABLE_READ_VERIFY=false

# Shadow sampling (0.0-1.0, default: 1.0 = 100%)
SHADOW_SAMPLE_RATE=1.0

# Dual Write timeout in ms (default: 2000)
DUAL_WRITE_TIMEOUT_MS=2000

# Shadow mode timeout in ms (default: 3000)
SHADOW_TIMEOUT_MS=3000
