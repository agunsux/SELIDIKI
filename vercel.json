{
  "version": 2,
  "installCommand": "cd backend && npm install",
  "buildCommand": "cd backend && npm install",
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "backend/server.js" },
    { "src": "/metrics", "dest": "backend/server.js" },
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/(.*)", "dest": "backend/server.js" }
  ],
  "functions": {
    "backend/server.js": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}